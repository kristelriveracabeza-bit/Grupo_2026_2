# STAGE 1: BUILD
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
# Instalamos TODO para el build si fuera necesario (o solo prod)
RUN npm ci --only=production

# STAGE 2: PRODUCCIÓN
FROM node:20-alpine
RUN apk add --no-cache tzdata
ENV TZ=America/Lima
WORKDIR /app

# Seguridad: Crear usuario de sistema
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

# Copiar dependencias 
COPY --from=builder --chown=nodejs:nodejs /app/node_modules ./node_modules

# Copiar el resto del código 
COPY --chown=nodejs:nodejs . .

# Aseguramos que el usuario tenga acceso a la carpeta app
RUN chown -R nodejs:nodejs /app

EXPOSE 3000
USER nodejs

# Health check optimizado
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "const http = require('http'); http.get('http://localhost:3000/health', (res) => { process.exit(res.statusCode === 200 ? 0 : 1); }).on('error', () => process.exit(1))"

CMD ["node", "index.js"]